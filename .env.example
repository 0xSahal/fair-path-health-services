# Copy to .env.local and fill in values. Restart `npm run dev` after any change.

# WRONG for local Windows dev (causes querySrv ECONNREFUSED):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=...

# CORRECT — Atlas: Connect → Drivers → "Standard connection string"
# Must start with mongodb:// and list hosts with :27017, for example:
# MONGODB_URI=mongodb://USER:PASS@cluster-shard-00-00.xxxxx.mongodb.net:27017,cluster-shard-00-01.xxxxx.mongodb.net:27017,cluster-shard-00-02.xxxxx.mongodb.net:27017/?ssl=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority&appName=your-app
MONGODB_URI=

# Database name in Atlas (avoids default "test"). Collections: home_page_inquiries, contact_page_inquiries
MONGODB_DB_NAME=fairpath
